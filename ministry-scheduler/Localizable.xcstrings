    "Credited time is sent to Hourglass automatically, labelled in the report remarks." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El tiempo acreditado se envía a Hourglass automáticamente, indicado en las observaciones del informe." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Angerechnete Zeit wird automatisch an Hourglass gesendet und in den Bemerkungen des Berichts ausgewiesen." } },
        "pt" : { "stringUnit" : { "state" : "translated", "value" : "O tempo creditado é enviado ao Hourglass automaticamente, indicado nas observações do relatório." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Il tempo accreditato viene inviato automaticamente a Hourglass, indicato nelle osservazioni del rapporto." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le temps crédité est envoyé automatiquement à Hourglass et indiqué dans les remarques du rapport." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "クレジット時間は自動的にHourglassへ送信され、報告の備考欄に記載されます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "抵算时间会自动发送到Hourglass，并标注在报告备注中。" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Czas zaliczony jest wysyłany do Hourglass automatycznie i oznaczony w uwagach sprawozdania." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Godskrevet tid sendes automatisk til Hourglass og merkes i rapportens merknader." } }
      }
    },
    "Send to Hourglass" : {
      "localizations" : {
