    "Sending opens Hourglass with the report form pre-filled; credited time is included in the remarks. Sharing works with any other reporting app on this phone." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Al enviar se abre Hourglass con el formulario del informe ya rellenado; el tiempo acreditado se incluye en las observaciones. Compartir funciona con cualquier otra app de informes de este teléfono." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Beim Senden öffnet sich Hourglass mit dem bereits ausgefüllten Berichtsformular; angerechnete Zeit steht in den Bemerkungen. Teilen funktioniert mit jeder anderen Berichts-App auf diesem Telefon." } },
        "pt" : { "stringUnit" : { "state" : "translated", "value" : "Ao enviar, o Hourglass abre com o formulário do relatório já preenchido; o tempo creditado é incluído nas observações. Compartilhar funciona com qualquer outro app de relatórios deste telefone." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "L’invio apre Hourglass con il modulo del rapporto già compilato; il tempo accreditato è incluso nelle osservazioni. La condivisione funziona con qualsiasi altra app per i rapporti su questo telefono." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L’envoi ouvre Hourglass avec le formulaire du rapport prérempli ; le temps crédité figure dans les remarques. Le partage fonctionne avec toute autre application de rapport sur ce téléphone." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "送信するとHourglassが開き、報告フォームが自動入力されます。クレジット時間は備考に含まれます。共有はこの端末にある他の報告アプリでも使えます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "发送时会打开Hourglass并自动填写报告表单；抵算时间包含在备注中。分享功能适用于本机上的任何其他报告应用。" } },
        "pl" : { "stringUnit" : { "state" : "translated", "value" : "Wysłanie otwiera Hourglass z wypełnionym formularzem sprawozdania; czas zaliczony jest ujęty w uwagach. Udostępnianie działa z każdą inną aplikacją do sprawozdań na tym telefonie." } },
        "nb" : { "stringUnit" : { "state" : "translated", "value" : "Sending åpner Hourglass med rapportskjemaet ferdig utfylt; godskrevet tid tas med i merknadene. Deling fungerer med alle andre rapportapper på denne telefonen." } }
      }
    },
